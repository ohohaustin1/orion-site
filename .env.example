# ─── orion-site env (Vite) ───
# 注意：以 VITE_ 開頭的變數會 inline 進 client bundle、不要放 secret

# ─── Hub API base ───
VITE_API_BASE_URL=https://orion-hub.zeabur.app

# ─── Public domain（用於 canonical URL / OG meta）───
VITE_PUBLIC_DOMAIN=https://orion01.com

# ─── 報告 staging URL token 保護（prod 限存取者）───
# 對應 orion-hub 的 REPORT_PREVIEW_TOKEN
# 留空：prod staging URL 不需 dev_token query
VITE_REPORT_PREVIEW_TOKEN=
